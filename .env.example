# JobGPT MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Your JobGPT API key
# Generate one at https://6figr.com/account (MCP Integrations section)
JOBGPT_API_KEY=mcp_your_api_key_here

# Optional: JobGPT API URL (defaults to production)
# For development, you can use http://localhost:3000
JOBGPT_API_URL=https://6figr.com

# Optional: Enable debug logging
DEBUG=false
